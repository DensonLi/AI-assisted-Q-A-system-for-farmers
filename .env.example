# ── 数据库 ──────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_strong_password_here

DATABASE_URL=postgresql+psycopg2://postgres:your_strong_password_here@postgres:5432/farming_qa
ASYNC_DATABASE_URL=postgresql+asyncpg://postgres:your_strong_password_here@postgres:5432/farming_qa

# ── Redis ────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── JWT ──────────────────────────────────────────────
# 生产环境请使用强随机密钥：openssl rand -hex 32
SECRET_KEY=change_this_to_a_random_secret_key_in_production

# ── 知识库 API（ziiku.cn RAG 服务）────────────────────
KNOWLEDGE_API_BASE_URL=https://center.ziiku.cn/api/aibot/openapi/conversation/chat
KNOWLEDGE_API_KEY=your_knowledge_api_key_here
KNOWLEDGE_BOT_ID=your_bot_id_here

# ── LLM（支持 DeepSeek / OpenAI 及其他 OpenAI 兼容服务）─────
# DeepSeek 示例：
LLM_API_KEY=sk-your_deepseek_or_openai_key_here
LLM_BASE_URL=https://api.deepseek.com       # 使用官方 OpenAI 时留空
LLM_MODEL=deepseek-chat                     # 或 gpt-4o、claude-sonnet-4-5 等
LLM_MAX_TOKENS=1500
LLM_TEMPERATURE=0.3
LLM_HISTORY_TURNS=5

# ── 初始管理员（首次启动自动创建）─────────────────────
FIRST_ADMIN_USERNAME=admin
FIRST_ADMIN_PASSWORD=Admin@123456
FIRST_ADMIN_EMAIL=admin@example.com
